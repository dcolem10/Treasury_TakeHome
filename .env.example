# Copy to .env and fill in. The app reads these at startup.

# Extraction backend: "claude" (prototype default) or "tesseract" (local/air-gapped path).
EXTRACTION_BACKEND=claude

# Required when EXTRACTION_BACKEND=claude.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides.
ANTHROPIC_MODEL=claude-opus-4-8
EXTRACTION_TIMEOUT_S=30
BATCH_CONCURRENCY=8
FUZZY_PASS=88
FUZZY_WARN=80

# Abuse protection: images (= paid vision calls) allowed per client per window.
# 0 disables. Default fits one full 300-label batch + singles per 10 minutes.
RATE_LIMIT_IMAGES=400
RATE_LIMIT_WINDOW_S=600
